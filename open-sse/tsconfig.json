{
  "compilerOptions": {
    "target": "ES2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "strict": false,
    "jsx": "react-jsx",
    "lib": ["dom", "esnext"],
    "paths": {
      "@/*": ["../src/*"],
      "@routiform/open-sse": ["./"],
      "@routiform/open-sse/*": ["./*"]
    }
  },
  "include": ["**/*.ts", "**/*.js"]
}
